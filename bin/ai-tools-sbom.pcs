#!/usr/bin/env python

""" #+begin_org
* Panel::  [[file:/bisos/panels/bisos-apps/NameOfThePanelComeHere/_nodeBase_/fullUsagePanel-en.org]]
* Overview and Relevant Pointers
#+end_org """

from bisos import b
# from bisos.b import cmndsSeed
from bisos.b import cs
from bisos.b import b_io

# import collections

from bisos.sbom import pkgsSeed  # pkgsSeed.plantWithWhich("seedSbom.cs")
ap = pkgsSeed.aptPkg
pp = pkgsSeed.pipPkg
sbom = pkgsSeed.sbomSpec

pkgsSeed.pkgsSeedInfo.virtenv = "/bisos/venv/py3/asc"

sbomsList = [
    sbom("/bisos/core/lcnt/bin/playwright-sbom.pcs"),  # required by crawl4ai for JS rendering
]

pipPkgsList = [
    pp("markitdown"),   # MS markitdown -- converts PDF/Word/HTML/etc to Markdown; importable as library
    pp("crawl4ai"),     # LLM-focused web crawler -- renders JS via playwright, outputs clean Markdown
    pp("docling"),      # IBM document parser -- PDF/DOCX/PPTX to structured Markdown; handles complex layouts
]

pkgsSeed.setup(
    pipPkgsList=pipPkgsList,
    sbomsList=sbomsList,
)


####+BEGIN: b:py3:cs:cmnd/classHead :cmndName "readme" :extent "verify" :comment "Describe" :parsMand "" :parsOpt "" :argsMin 0 :argsMax 0 :pyInv ""
""" #+begin_org
*  _[[elisp:(blee:menu-sel:outline:popupMenu)][±]]_ _[[elisp:(blee:menu-sel:navigation:popupMenu)][Ξ]]_ [[elisp:(outline-show-branches+toggle)][|=]] [[elisp:(bx:orgm:indirectBufOther)][|>]] *[[elisp:(blee:ppmm:org-mode-toggle)][|N]]*  CmndSvc-   [[elisp:(outline-show-subtree+toggle)][||]] <<readme>>  *Describe*  =verify= ro=cli   [[elisp:(org-cycle)][| ]]
#+end_org """
class readme(cs.Cmnd):
    cmndParamsMandatory = [ ]
    cmndParamsOptional = [ ]
    cmndArgsLen = {'Min': 0, 'Max': 0,}

    @cs.track(fnLoc=True, fnEntry=True, fnExit=True)
    def cmnd(self,
             rtInv: cs.RtInvoker,
             cmndOutcome: b.op.Outcome,
    ) -> b.op.Outcome:
        """Describe"""
        failed = b_io.eh.badOutcome
        callParamsDict = {}
        if self.invocationValidate(rtInv, cmndOutcome, callParamsDict, None).isProblematic():
            return failed(cmndOutcome)
####+END:
        descriptionStr = """\
** Scope: AI/LLM-adjacent document ingestion tools installed via pip into /bisos/venv/py3/asc.
   Prerequisite sbom: /bisos/core/lcnt/bin/playwright-sbom.pcs (required by crawl4ai).

** Components installed:

  1) markitdown  (microsoft/markitdown)
       - Converts PDF, Word, Excel, PowerPoint, HTML, images, audio, ZIP, etc. to Markdown.
       - CLI: markitdown <file>
       - Library: from markitdown import MarkItDown

  2) crawl4ai
       - LLM-focused web crawler; renders JavaScript via Playwright, outputs clean Markdown.
       - Supports deep crawl, CSS/LLM-guided extraction, cosine-similarity filtering.
       - CLI: crawl4ai-download-models  (post-install model fetch)
       - Library: from crawl4ai import AsyncWebCrawler

  3) docling  (IBM Research)
       - Parses complex PDF, DOCX, PPTX, HTML to structured Markdown or JSON.
       - Handles multi-column layouts, tables, figures, reading order.
       - Integrates with LangChain, LlamaIndex, Hugging Face datasets.
       - Library: from docling.document_converter import DocumentConverter

** Installation:
       ai-tools-sbom.pcs -i sbom_fullUpdate

** Update:
       /bisos/venv/py3/asc/bin/pip install --upgrade markitdown crawl4ai docling\
"""
        print(descriptionStr)

        return cmndOutcome.set(
            opError=b.op.OpError.Success,
            opResults=None,
        )

def examples_csu() -> b.op.Outcome:
    """Common Usage Examples for this Command-Service Unit"""

    cmnd = cs.examples.cmndEnter
    literal = cs.examples.execInsert

    cmndOutcome = b.op.Outcome()

    cs.examples.menuChapter('*markitdown Examples*')
    if not (resStr := b.subProc.Op(outcome=cmndOutcome, log=0).bash(
       f"""which markitdown""").stdout):
        pass

    literal(f"which markitdown # {resStr.strip()}")
    literal("markitdown --help")

    cmnd('readme', comment=" # An overview short description")

    cs.examples.menuChapter('*Install / Update*')
    literal("ai-tools-sbom.pcs -i sbom_fullUpdate")
    literal("/bisos/venv/py3/asc/bin/pip install --upgrade markitdown crawl4ai docling  # manual update")

    cs.examples.menuChapter('*markitdown -- Convert Files to Markdown*')
    literal("markitdown document.pdf")
    literal("markitdown page.html")
    literal("markitdown spreadsheet.xlsx")
    literal("markitdown presentation.pptx")

    cs.examples.menuChapter('*markitdown -- Python Library Usage*')
    literal("python3 -c \"from markitdown import MarkItDown; md = MarkItDown(); print(md.convert('file.pdf').text_content)\"")

    cs.examples.menuChapter('*crawl4ai -- Web Crawling to Markdown*')
    literal("python3 -c \"import asyncio; from crawl4ai import AsyncWebCrawler; asyncio.run(AsyncWebCrawler().arun(url='https://example.com'))\"")

    cs.examples.menuChapter('*docling -- Document Parsing*')
    literal("python3 -c \"from docling.document_converter import DocumentConverter; print(DocumentConverter().convert('document.pdf').document.export_to_markdown())\"")

    cs.examples.menuChapter('*Uninstall*')
    literal("/bisos/venv/py3/asc/bin/pip uninstall markitdown crawl4ai docling")

    cs.examples.menuChapter('*End-Of  AI Tools Command Examples*')
    return cmndOutcome